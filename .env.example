# ──────────────────────────────────────────────
# minimoes-tts-sst — Environment variables
# Copy to .env and fill in real values.
# On RunPod: set these in the pod template → Environment Variables section.
# ──────────────────────────────────────────────

# REQUIRED — Authentication key for all API endpoints and WebSocket connections.
# Same value must be set in RUNPOD_API_KEY on the Next.js (minimoes) service.
RUNPOD_API_KEY=REPLACE_WITH_RUNPOD_API_KEY

# REQUIRED — Groq API key for LLM inference (llama-4-scout-17b and llama-3.3-70b-versatile).
# Get it at https://console.groq.com → API Keys.
GROQ_API_KEY=REPLACE_WITH_GROQ_API_KEY

# OPTIONAL — STT model size: tiny, base, small, medium, large-v2, large-v3 (default: base).
# Larger = more accurate but slower first-token latency. base is the best latency/accuracy tradeoff.
STT_MODEL_SIZE=base

# OPTIONAL — Max concurrent GPU pipelines (LLM+TTS+BS). Default: 3.
# Lower if you see VRAM OOM; raise if GPU has spare headroom.
MAX_CONCURRENT_PIPELINES=3

# OPTIONAL — Session TTL in seconds. Default: 7200 (2h).
# Increase if users have very long sessions; decrease to free VRAM faster.
SESSION_TTL_SECONDS=7200

# OPTIONAL — Set to 0 to disable torch.compile (faster restart, slower inference).
ENABLE_TORCH_COMPILE=1

# OPTIONAL — TTS voice reference audio path and reference text.
# If set, these override per-request voice_id.
# TTS_REF_AUDIO_PATH=/app/voices/default.wav
# TTS_REF_TEXT=Hello, this is a reference text for the voice.

# OPTIONAL — Server tuning (rarely need changing)
PORT=7860
UVICORN_WORKERS=1
UVICORN_KEEPALIVE=75
UVICORN_GRACEFUL_TIMEOUT=30
